# Resend (https://resend.com) — required for the contact form API
# No quotes around the key (or the server strips them if you add quotes by mistake)
RESEND_API_KEY=

# Inbox for contact submissions (defaults in code if unset).
# If CONTACT_FROM_EMAIL uses onboarding@resend.dev, CONTACT_TO_EMAIL must be the
# same email you use to log into Resend, OR verify a domain and use that domain in "from".
CONTACT_TO_EMAIL=mahmoudria94@gmail.com

# Verified sender in Resend; use onboarding@resend.dev for local testing
CONTACT_FROM_EMAIL=JudyTech <onboarding@resend.dev>
